# Mock mode – routes are served by Next.js itself (no separate backend required).
# Copy this file to .env.local and run `pnpm dev` to play with the mystorage UI
# using in-memory mock data.
#
# Demo credentials: demo@example.com / demo1234
# (Any other email/password combination is also accepted and auto-registered.)

NEXT_PUBLIC_API_URL=http://localhost:3000
